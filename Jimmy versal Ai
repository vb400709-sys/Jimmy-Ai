<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>AI Chat Bot</title>

<style>
body{
    font-family:Arial;
    background:#f0f0f0;
}
#chat{
    width:90%;
    height:400px;
    margin:20px auto;
    background:#fff;
    border:1px solid #ccc;
    overflow-y:auto;
    padding:10px;
}
.user{
    text-align:right;
    margin:10px;
}
.bot{
    text-align:left;
    margin:10px;
}
.msg{
    display:inline-block;
    padding:10px;
    border-radius:10px;
    background:#d9fdd3;
}
.bot .msg{
    background:#eeeeee;
}
#text{
    width:75%;
    padding:10px;
}
button{
    padding:10px 20px;
}
</style>
</head>

<body>

<div id="chat"></div>

<center>
<input type="text" id="text" placeholder="Type message...">
<button onclick="send()">Send</button>
</center>

<script>
function send(){

let input=document.getElementById("text");
let message=input.value.trim();

if(message=="") return;

let chat=document.getElementById("chat");

chat.innerHTML += `
<div class="user">
<div class="msg">${message}</div>
</div>
`;

input.value="";

let reply="Sorry, I don't understand.";

let msg=message.toLowerCase();

if(msg=="hi" || msg=="hello"){
    reply="Hello! How are you?";
}
else if(msg=="how are you"){
    reply="I am fine. What about you?";
}
else if(msg=="your name"){
    reply="My name is AI Bot.";
}
else if(msg=="bye"){
    reply="Good Bye!";
}

setTimeout(function(){

chat.innerHTML += `
<div class="bot">
<div class="msg">${reply}</div>
</div>
`;

chat.scrollTop=chat.scrollHeight;

},500);

}
</script>

</body>
</html>